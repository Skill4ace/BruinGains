{
  "expo": {
    "name": "BruinGains",
    "slug": "BruinGains",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./appassets/bruingains app icons.png",
    "scheme": "bruingains",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.skill4ace.bruingains",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./appassets/bruingains app icons.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./appassets/bruingains app icons.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./appassets/bruingains splash screen.png",
          "imageWidth": 1080,
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
